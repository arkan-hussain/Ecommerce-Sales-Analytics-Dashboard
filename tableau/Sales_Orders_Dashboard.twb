            <zone h='24000' id='51' name='Monthly Sales Trend' show-title='true' w='100000' x='0' y='18000' />
          </zone>
          <zone h='29000' id='6' param='horz' type-v2='layout-flow' w='100000' x='0' y='42000'>
            <zone h='29000' id='61' name='Revenue by Category' show-title='true' w='50000' x='0' y='42000' />
            <zone h='29000' id='62' name='Revenue by State' show-title='true' w='50000' x='50000' y='42000' />
          </zone>
          <zone h='29000' id='7' param='horz' type-v2='layout-flow' w='100000' x='0' y='71000'>
            <zone h='29000' id='71' name='Top Products' show-title='true' w='50000' x='0' y='71000' />
            <zone h='29000' id='72' name='Order Status Summary' show-title='true' w='50000' x='50000' y='71000' />
          </zone>
        </zone>
      </zones>
      <devicelayouts>
        <devicelayout auto-generated='true' name='Phone'>
          <size maxheight='2000' minheight='2000' sizing-mode='vscroll' />
          <zones>
            <zone h='100000' id='199' type-v2='layout-basic' w='100000' x='0' y='0'>
            <zone h='11111' id='200' name='KPI - Total Orders' w='100000' x='0' y='0' />
            <zone h='11111' id='201' name='KPI - Total Customers' w='100000' x='0' y='11111' />
            <zone h='11111' id='202' name='KPI - Total Revenue' w='100000' x='0' y='22222' />
            <zone h='11111' id='203' name='KPI - Avg Order Value' w='100000' x='0' y='33333' />
            <zone h='11111' id='204' name='Monthly Sales Trend' w='100000' x='0' y='44444' />
            <zone h='11111' id='205' name='Revenue by Category' w='100000' x='0' y='55555' />
            <zone h='11111' id='206' name='Revenue by State' w='100000' x='0' y='66666' />
            <zone h='11111' id='207' name='Top Products' w='100000' x='0' y='77777' />
            <zone h='11111' id='208' name='Order Status Summary' w='100000' x='0' y='88888' />
